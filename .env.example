# GitHub API (repos e perfil — inclui privados com escopo repo)
VITE_GITHUB_ACCESS_TOKEN=

# EmailJS (formulario de contato)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# LinkedIn posts (escolha UMA opcao — ver docs/linkedin-setup.md)
#
# RECOMENDADO: posts manuais (funciona sempre, sem RSS nem API)
# Edite lib/linkedin/manualPosts.ts OU use JSON abaixo (uma linha):
# LINKEDIN_MANUAL_POSTS=[{"id":"1","title":"...","excerpt":"...","url":"https://www.linkedin.com/feed/update/...","publishedAt":"2026-05-24T12:00:00.000Z"}]
LINKEDIN_MANUAL_POSTS=

# Opcional: feed RSS (so funciona bem com pagina /company/, nao perfil /in/)
LINKEDIN_RSS_URL=

# Opcional: LinkedIn API (dev individual raramente consegue ler posts)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_MEMBER_URN=
