{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "yarn install --frozen-lockfile --force",
  "buildCommand": "yarn build",
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/icon-48.png"
    },
    {
      "source": "/recruiter",
      "destination": "/index.html"
    },
    {
      "source": "/api/og",
      "has": [{ "type": "query", "key": "lang", "value": "en" }],
      "destination": "/og-en.png"
    },
    {
      "source": "/api/og",
      "destination": "/og-pt.png"
    }
  ],
  "headers": [
    {
      "source": "/og-(pt|en).png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/icon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, immutable"
        }
      ]
    },
    {
      "source": "/icon-:size(48|192).png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, immutable"
        }
      ]
    },
    {
      "source": "/apple-touch-icon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, immutable"
        }
      ]
    }
  ]
}
